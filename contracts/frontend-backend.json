        "method": "GET",
        "path": "/api/coupons"
      },
      "response": {
        "body": {
          "coupons": [
            {
              "code": "SAVE10",
              "discountRate": 0.2,
              "usageLimit": 100,
              "usedCount": 0
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.coupons": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.coupons[*].code": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.coupons[*].discountRate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
