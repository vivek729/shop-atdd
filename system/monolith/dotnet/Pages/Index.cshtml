@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="jumbotron bg-light p-5 rounded">
    <h1 class="display-4">Welcome to MyShop!</h1>
    <p class="lead">Your modern e-commerce solution</p>
    <hr class="my-4" />
    <div class="row mt-4">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">New Order</h5>
                    <p class="card-text">Place a new order with our easy-to-use interface</p>
                    <a class="btn btn-primary" href="/new-order">New Order</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Order History</h5>
                    <p class="card-text">View and manage your past orders</p>
                    <a class="btn btn-primary" href="/order-history">View Orders</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Coupon Management</h5>
                    <p class="card-text">Admin panel for managing discount coupons</p>
                    <a class="btn btn-primary" href="/admin-coupons">Manage Coupons</a>
                </div>
            </div>
        </div>
    </div>
</div>
