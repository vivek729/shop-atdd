project:
  provider: github
  url: https://github.com/orgs/optivem/projects/20
repo-strategy: mono-repo
sonar:
  organization: optivem
system:
  architecture: multitier
  config: docker/${SYSTEM_LANG}/multitier/systems.yaml
  backend:
    path: system/multitier/backend-${SYSTEM_LANG}
    repo: optivem/shop
    lang: ${SYSTEM_LANG}
    sonar-project: optivem_shop-multitier-backend-${SYSTEM_LANG}
  frontend:
    path: system/multitier/frontend-react
    repo: optivem/shop
    lang: typescript
    sonar-project: optivem_shop-multitier-frontend-react
system-test:
  path: system-test/${TEST_LANG}
  config: ${TEST_CONFIG}
  repo: optivem/shop
  lang: ${TEST_LANG}
  sonar-project: optivem_shop-tests-${TEST_LANG}
