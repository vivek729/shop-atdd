project:
  url: https://github.com/orgs/optivem/projects/20
repo_strategy: mono-repo
system:
  architecture: multitier
  config: docker/${SYSTEM_LANG}/multitier/systems.yaml
  backend:
    path: system/multitier/backend-${SYSTEM_LANG}
    repo: optivem/shop
    lang: ${SYSTEM_LANG}
  frontend:
    path: system/multitier/frontend-react
    repo: optivem/shop
    lang: typescript
system_test:
  path: system-test/${TEST_LANG}
  config: ${TEST_CONFIG}
  repo: optivem/shop
  lang: ${TEST_LANG}
